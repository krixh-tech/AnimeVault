# ── AnimaVault Environment Variables ──────────────────────────────────
# Copy this to .env and fill in your values

# ── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:animavault_secret@localhost:27017/animavault?authSource=admin
MONGO_USER=admin
MONGO_PASS=animavault_secret

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASS=redis_secret

# ── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production_min_64_chars
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens_min_64_chars

# ── Storage ────────────────────────────────────────────────────────────
# Options: local | s3
STORAGE_MODE=local

# S3 / Cloudflare R2 (only needed if STORAGE_MODE=s3)
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
# For Cloudflare R2:
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ── Email (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── Telegram Bot (optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Worker ─────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend (Next.js) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=http://localhost:5000
